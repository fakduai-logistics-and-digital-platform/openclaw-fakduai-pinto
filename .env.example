# Image name created by Docker Compose.
OPENCLAW_IMAGE=openclaw-pinto:local

# Base OpenClaw image. Pin this to a version for production, for example:
# OPENCLAW_BASE_IMAGE=ghcr.io/openclaw/openclaw:2026.5.24
OPENCLAW_BASE_IMAGE=ghcr.io/openclaw/openclaw:latest

# Pinto plugin source.
PINTO_PLUGIN_REPO=https://github.com/jatura-fakduai/pinto-openclaw-gateway.git
PINTO_PLUGIN_REF=main

# Gateway access.
OPENCLAW_GATEWAY_PORT=18789
# Generate a real value with: sh scripts/reset-login-token.sh
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_TZ=UTC

# Public URL helpers. These are not required by Docker Compose, but make setup
# easier to share and copy into Pinto.
PUBLIC_OPENCLAW_URL=http://127.0.0.1:18789
PINTO_WEBHOOK_URL=http://127.0.0.1:18789/plugins/pinto/webhook

# Optional: Cloudflare Tunnel token.
# Create a remotely-managed tunnel in Cloudflare, add a public hostname that
# points to http://openclaw-gateway:18789, then paste the token here.
# CLOUDFLARE_TUNNEL_TOKEN=eyJ...

# The image contains the plugin package. Keep these enabled so a fresh
# OpenClaw volume installs and enables Pinto automatically.
PINTO_PLUGIN_AUTO_INSTALL=1
PINTO_PLUGIN_AUTO_ENABLE=1
